scripts/extraction/raw_text/
# Candidate CSV with course-source info (large, intermediate)
scripts/extraction/candidates.csv
scripts/extraction/by_category/
# Batch input/output JSONs from the agent generation phase
scripts/extraction/batches/

# Secrets — never commit (Azure key, etc.)
.env
.env.local
*.key

# Mockup HTML — design preview, not part of the app
mockup/
